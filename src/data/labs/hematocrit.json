  "critical_values": [
    {
      "condition": { "op": "lt", "value": 21.0, "unit": "%" },
      "meaning": "Severe anemia; high risk of cardiopulmonary compromise, consider immediate transfusion."
    },
    {
      "condition": { "op": "gt", "value": 60.0, "unit": "%" },
      "meaning": "Severe polycythemia; risk of hyperviscosity syndrome and thrombosis."
    }
  ],
  "warnings": [
    "Reference ranges are physiologically higher in populations living at high altitudes and in heavy smokers.",
    "Hemodilution during the second and third trimesters of pregnancy naturally lowers hematocrit concentrations.",
    "Severe dehydration can cause falsely elevated hematocrit levels.",
    "Pediatric ranges are highly age-dependent; ensure exact age is used for interpretation."
  ],
  "notes": [
    "The physiologic nadir in infancy occurs around 8-12 weeks as fetal hemoglobin (HbF) is replaced by adult hemoglobin (HbA).",
    "Neonatal values vary significantly based on timing of cord clamping and gestational age."
