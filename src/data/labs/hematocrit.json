  "critical_values": [
    {
      "condition": { "op": "le", "value": 21, "unit": "%" },
      "meaning": "Critical anemia; high risk of cardiopulmonary compromise, heart failure, and death; consider immediate transfusion",
      "note": "Some institutions use a threshold of <20% (any age) or <19.7% as an alert value.",
