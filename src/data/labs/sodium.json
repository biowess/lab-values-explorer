  "interpretation_rules": [
    {
      "condition": {
        "op": "lt",
        "value": 135,
        "unit": "mmol/L"
      },
      "meaning": "Hyponatremia: May result from fluid overload, sodium loss (diuretics, diarrhea), or SIADH."
    },
    {
      "condition": {
        "op": "gt",
        "value": 145,
        "unit": "mmol/L"
      },
      "meaning": "Hypernatremia: May indicate dehydration, excessive salt intake, or diabetes insipidus."
    }
  ],
  "critical_values": [
    {
      "condition": {
        "op": "lte",
        "value": 120,
        "unit": "mmol/L"
      },
      "meaning": "Severe hyponatremia: High risk of cerebral edema and seizures."
    },
    {
      "condition": {
        "op": "gte",
        "value": 160,
        "unit": "mmol/L"
      },
      "meaning": "Severe hypernatremia: Risk of brain shrinkage, intracranial hemorrhage, and coma."
    }
  ],
  "warnings": [
    "Pseudohyponatremia may occur in cases of severe hyperlipidemia or hyperproteinemia depending on the laboratory method used.",
    "Correction of chronic hyponatremia must be gradual to avoid osmotic demyelination syndrome."
  ],
  "notes": [
    "Sodium levels should always be interpreted alongside clinical volume status (hypovolemic, euvolemic, or hypervolemic).",
    "Reference intervals for neonates are slightly wider due to physiological transitions in fluid distribution and renal handling of sodium in the first weeks of life."
  ],
